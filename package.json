{
  "name": "last-health-miniapp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "dev:server": "tsx src/server.ts",
    "dev:weapp": "taro build --type weapp --watch",
    "build:weapp": "taro build --type weapp",
    "build:h5": "taro build --type h5",
    "dev:h5": "taro build --type h5 --watch",
    "start": "npm run build:h5 && node --import tsx src/server.ts"
  },
  "devDependencies": {
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@tarojs/cli": "^4.2.0",
    "@tarojs/components": "^4.2.0",
    "@tarojs/plugin-framework-react": "^4.2.0",
    "@tarojs/plugin-platform-h5": "^4.2.0",
    "@tarojs/plugin-platform-weapp": "^4.2.0",
    "@tarojs/react": "^4.2.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "tsx": "^4.22.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "webpack": "^5.91.0"
  },
  "dependencies": {
    "@tarojs/taro": "^4.2.0",
    "@tarojs/webpack5-runner": "^4.2.0",
    "bcryptjs": "^3.0.3",
    "express": "^5.2.1",
    "mysql2": "^3.22.4",
    "pinyin-pro": "^3.28.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "supertest": "^7.2.2"
  }
}
